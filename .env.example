# Environment Configuration for Local File Storage System
# Copy this file to .env and adjust values as needed

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# CORS Allowed Hosts (comma-separated)
# Use "*" for all hosts (development)
# Specify specific hosts for production: "http://localhost:3000,http://example.com"
ALLOWED_HOSTS=*

# Server Configuration
HOST=0.0.0.0
PORT=8000
